// نظام إدارة الأعمال العلمية — مؤسسة ساعي
// Prisma 7 — driver adapter (@prisma/adapter-pg) إلزامي
// كل الجداول tenantId="saei" + createdAt + updatedAt + indexes مناسبة

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// المستخدمون (NextAuth-compatible) + الأدوار
// ============================================================

model User {
  id        String   @id @default(cuid())
  tenantId  String   @default("saei")
  email     String   @unique
  name      String?
  password  String?
  image     String?
  role      UserRole @default(RESEARCHER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  researcher Researcher?
  reviewer   Reviewer?

  @@index([tenantId])
}

enum UserRole {
  ADMIN                  // مدير النظام
  RESEARCH_COORDINATOR   // منسق الأبحاث
  JOURNAL_COORDINATOR    // منسق المجلة
  RESEARCHER             // باحث
  REVIEWER               // محكم
}

// ============================================================
// الباحث — ملف موسّع لمستخدم بدور RESEARCHER
// ============================================================

model Researcher {
  id            String   @id @default(cuid())
  tenantId      String   @default("saei")
  userId        String   @unique
  displayName   String
  academicTitle String?
  specialty     String?
  bio           String?
  joinedAt      DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user  User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  works ScientificWork[] @relation("WorkOwner")

  @@index([tenantId])
}

// ============================================================
// المراجع — ملف موسّع لمستخدم بدور REVIEWER
// ============================================================

model Reviewer {
  id          String   @id @default(cuid())
  tenantId    String   @default("saei")
  userId      String   @unique
  expertise   String?
  bio         String?
  // قائمة التخصصات (codes تطابق WorkSpecialty في types/works.ts)
  specialties String[] @default([])
  // إحصاءات الأداء — تُحدَّث من جانب التطبيق (مشتقّة)
  totalAssigned  Int   @default(0)
  totalCompleted Int   @default(0)
  active         Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviews Review[]

  @@index([tenantId])
  @@index([active])
}

// ============================================================
// مراحل سير العمل — جدول مرجعي قابل للتوسعة
// ============================================================

model WorkflowStage {
  id        String   @id @default(cuid())
  tenantId  String   @default("saei")
  code      String   @unique
  label     String
  order     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  works ScientificWork[]

  @@index([tenantId])
}

// ============================================================
// الأعمال العلمية — الكيان المركزي
// ============================================================

model ScientificWork {
  id           String    @id @default(cuid())
  tenantId     String    @default("saei")
  code         String    @unique
  title        String
  specialty    String
  track        WorkTrack
  researcherId String
  stageCode    String
  progress     Int       @default(0)
  startedAt    DateTime
  deadline     DateTime
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  researcher  Researcher       @relation("WorkOwner", fields: [researcherId], references: [id], onDelete: Restrict)
  stage       WorkflowStage    @relation(fields: [stageCode], references: [code])
  reviews     Review[]
  submissions WorkSubmission[]
  contracts   Contract[]

  @@index([tenantId])
  @@index([researcherId])
  @@index([stageCode])
  @@index([track])
  @@index([deadline])
}

enum WorkTrack {
  BOOK
  JOURNAL
  THESIS
  ARTICLE
}

// ============================================================
// المراجعات — تقييم العمل من قِبل مراجع
// ============================================================

model Review {
  id         String       @id @default(cuid())
  tenantId   String       @default("saei")
  workId     String
  reviewerId String
  status     ReviewStatus @default(ASSIGNED)

  // درجات تقييم من ١-١٠ (تظهر للمنسق فقط، لا للباحث)
  scientificScore Int?
  linguisticScore Int?
  methodologyScore Int?

  // قرار المحكم النهائي
  decision   ReviewDecision?

  // ملاحظات منظمة
  recommendations String? @db.Text  // ملاحظات للباحث (مجهولة المصدر)
  notesToEditor   String? @db.Text  // ملاحظات سرية للمنسق

  // التواريخ
  assignedAt     DateTime  @default(now())
  dueDate        DateTime?
  submittedAt    DateTime?
  lastRemindedAt DateTime?
  declinedAt     DateTime?
  declineReason  String?

  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  work     ScientificWork @relation(fields: [workId], references: [id], onDelete: Cascade)
  reviewer Reviewer       @relation(fields: [reviewerId], references: [id], onDelete: Restrict)

  @@unique([workId, reviewerId])
  @@index([tenantId])
  @@index([workId])
  @@index([reviewerId])
  @@index([status])
  @@index([dueDate])
}

enum ReviewStatus {
  ASSIGNED      // تمّ التعيين، لم يبدأ بعد
  IN_PROGRESS   // المحكم بدأ العمل
  SUBMITTED     // تمّ الإرسال (يتضمن قراراً)
  DECLINED      // المحكم اعتذر عن المراجعة
}

enum ReviewDecision {
  ACCEPT          // قبول
  MINOR_REVISION  // تعديلات يسيرة
  MAJOR_REVISION  // تعديلات جوهرية
  REJECT          // رفض
}

// ============================================================
// سجل التدقيق — يلتقط عمليات حساسة كـImpersonation
// ============================================================

model AuditLog {
  id        String      @id @default(cuid())
  tenantId  String      @default("saei")
  action    AuditAction
  actorId   String      // مَن نفّذ الإجراء (الأدمن في الانتحال)
  targetId  String?     // المستخدم المستهدف (المنتحل)
  ip        String?
  userAgent String?
  metadata  Json?
  createdAt DateTime    @default(now())
  endedAt   DateTime?   // وقت الإنهاء (للجلسات المؤقتة كالانتحال)

  @@index([tenantId])
  @@index([actorId])
  @@index([targetId])
  @@index([action])
  @@index([createdAt])
}

enum AuditAction {
  IMPERSONATE_START
  IMPERSONATE_END
}

// ============================================================
// تسليمات العمل العلمي — إصدارات الملفات (DRAFT أوّلي / منقّح)
// — حقل storagePath فارغ مبدئياً؛ يُملأ عندما يُضاف Supabase Storage
// ============================================================

model WorkSubmission {
  id         String              @id @default(cuid())
  tenantId   String              @default("saei")
  workId     String
  version    Int                 // 1, 2, 3, … تلقائي
  kind       SubmissionKind      @default(FIRST_DRAFT)
  fileName   String              // الاسم الأصلي
  mimeType   String              // application/pdf, application/msword, etc.
  size       Int                 // بايت
  storagePath String?            // مسار Supabase Storage (يُملأ لاحقاً)
  uploadedBy String               // userId
  uploadedAt DateTime            @default(now())
  notes      String?             @db.Text

  work ScientificWork @relation(fields: [workId], references: [id], onDelete: Cascade)

  @@unique([workId, version])
  @@index([tenantId])
  @@index([workId])
  @@index([uploadedBy])
  @@index([uploadedAt])
}

enum SubmissionKind {
  FIRST_DRAFT
  REVISION
  FINAL
}

// ============================================================
// الإشعارات — داخل التطبيق (DB-backed)
// ============================================================

model Notification {
  id        String           @id @default(cuid())
  tenantId  String           @default("saei")
  userId    String           // المستلم
  kind      NotificationKind
  title     String
  body      String?          @db.Text
  link      String?          // مسار للنقر داخل التطبيق
  metadata  Json?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([tenantId])
  @@index([userId, readAt])
  @@index([userId, createdAt])
  @@index([kind])
}

enum NotificationKind {
  STAGE_CHANGED
  REVIEW_ASSIGNED
  REVIEW_SUBMITTED
  SUBMISSION_RECEIVED
  DEADLINE_APPROACHING
  DEADLINE_OVERDUE
  CONTRACT_SIGNED
  CONTRACT_SENT
  GENERIC
}

// ============================================================
// العقود — أبحاث/نشر/تحرير مع علامات صلاحيات ودفعات
// ============================================================

model Contract {
  id        String         @id @default(cuid())
  tenantId  String         @default("saei")
  workId    String
  kind      ContractKind   @default(RESEARCH)
  status    ContractStatus @default(DRAFT)
  title     String
  body      String         @db.Text   // قالب نصّي قابل للطباعة
  startsAt  DateTime?
  endsAt    DateTime?
  value     Decimal?       @db.Decimal(12, 2)
  currency  String         @default("SAR")
  partyName String                                      // اسم الطرف الآخر (الباحث/الناشر)
  partyEmail String?                                    // اختياري
  signedById String?                                    // userId — مَن وقَّع
  signedAt   DateTime?
  signatureNote String?
  milestones Json?         // [{label, dueDate, amount, paidAt?}]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  work ScientificWork @relation(fields: [workId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([workId])
  @@index([status])
  @@index([endsAt])
}

enum ContractKind {
  RESEARCH
  PUBLISHING
  EDITING
}

enum ContractStatus {
  DRAFT
  SENT
  SIGNED
  EXPIRED
  CANCELLED
}
