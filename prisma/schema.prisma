// نظام إدارة الأعمال العلمية — مؤسسة ساعي
// Prisma 7 — driver adapter (@prisma/adapter-pg) إلزامي
// كل الجداول tenantId="saei" + createdAt + updatedAt + indexes مناسبة

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// المستخدمون (NextAuth-compatible) + الأدوار
// ============================================================

model User {
  id        String   @id @default(cuid())
  tenantId  String   @default("saei")
  email     String   @unique
  name      String?
  password  String?
  image     String?
  role      UserRole @default(RESEARCHER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  researcher Researcher?
  reviewer   Reviewer?

  @@index([tenantId])
}

enum UserRole {
  ADMIN                  // مدير النظام
  RESEARCH_COORDINATOR   // منسق الأبحاث
  JOURNAL_COORDINATOR    // منسق المجلة
  PRINTING_MANAGER       // مدير الطباعة (أُضيف في Phase C)
  RESEARCHER             // باحث
  REVIEWER               // محكم
}

// ============================================================
// الباحث — ملف موسّع لمستخدم بدور RESEARCHER
// ============================================================

model Researcher {
  id            String   @id @default(cuid())
  tenantId      String   @default("saei")
  userId        String   @unique
  displayName   String
  academicTitle String?
  specialty     String?
  bio           String?
  joinedAt      DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user  User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  works ScientificWork[] @relation("WorkOwner")

  @@index([tenantId])
}

// ============================================================
// المراجع — ملف موسّع لمستخدم بدور REVIEWER
// ============================================================

model Reviewer {
  id          String   @id @default(cuid())
  tenantId    String   @default("saei")
  userId      String   @unique
  expertise   String?
  bio         String?
  // قائمة التخصصات (codes تطابق WorkSpecialty في types/works.ts)
  specialties String[] @default([])
  // إحصاءات الأداء — تُحدَّث من جانب التطبيق (مشتقّة)
  totalAssigned  Int   @default(0)
  totalCompleted Int   @default(0)
  active         Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviews Review[]

  @@index([tenantId])
  @@index([active])
}

// ============================================================
// مراحل سير العمل — جدول مرجعي قابل للتوسعة
// ============================================================

model WorkflowStage {
  id        String   @id @default(cuid())
  tenantId  String   @default("saei")
  code      String   @unique
  label     String
  order     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  works ScientificWork[]

  @@index([tenantId])
}

// ============================================================
// الأعمال العلمية — الكيان المركزي
// ============================================================

model ScientificWork {
  id           String    @id @default(cuid())
  tenantId     String    @default("saei")
  code         String    @unique
  title        String
  specialty    String
  track        WorkTrack
  researcherId String
  stageCode    String
  progress     Int       @default(0)
  startedAt    DateTime
  deadline     DateTime
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  researcher  Researcher       @relation("WorkOwner", fields: [researcherId], references: [id], onDelete: Restrict)
  stage       WorkflowStage    @relation(fields: [stageCode], references: [code])
  reviews     Review[]
  submissions WorkSubmission[]
  contracts   Contract[]

  @@index([tenantId])
  @@index([researcherId])
  @@index([stageCode])
  @@index([track])
  @@index([deadline])
}

enum WorkTrack {
  BOOK
  JOURNAL
  THESIS
  ARTICLE
}

// ============================================================
// المراجعات — تقييم العمل من قِبل مراجع
// ============================================================

model Review {
  id         String       @id @default(cuid())
  tenantId   String       @default("saei")
  workId     String
  reviewerId String
  status     ReviewStatus @default(ASSIGNED)

  // درجات تقييم من ١-١٠ (تظهر للمنسق فقط، لا للباحث)
  scientificScore Int?
  linguisticScore Int?
  methodologyScore Int?

  // قرار المحكم النهائي
  decision   ReviewDecision?

  // ملاحظات منظمة
  recommendations String? @db.Text  // ملاحظات للباحث (مجهولة المصدر)
  notesToEditor   String? @db.Text  // ملاحظات سرية للمنسق

  // التواريخ
  assignedAt     DateTime  @default(now())
  dueDate        DateTime?
  submittedAt    DateTime?
  lastRemindedAt DateTime?
  declinedAt     DateTime?
  declineReason  String?

  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  work     ScientificWork @relation(fields: [workId], references: [id], onDelete: Cascade)
  reviewer Reviewer       @relation(fields: [reviewerId], references: [id], onDelete: Restrict)

  @@unique([workId, reviewerId])
  @@index([tenantId])
  @@index([workId])
  @@index([reviewerId])
  @@index([status])
  @@index([dueDate])
}

enum ReviewStatus {
  ASSIGNED      // تمّ التعيين، لم يبدأ بعد
  IN_PROGRESS   // المحكم بدأ العمل
  SUBMITTED     // تمّ الإرسال (يتضمن قراراً)
  DECLINED      // المحكم اعتذر عن المراجعة
}

enum ReviewDecision {
  ACCEPT          // قبول
  MINOR_REVISION  // تعديلات يسيرة
  MAJOR_REVISION  // تعديلات جوهرية
  REJECT          // رفض
}

// ============================================================
// سجل التدقيق — يلتقط عمليات حساسة كـImpersonation
// ============================================================

model AuditLog {
  id        String      @id @default(cuid())
  tenantId  String      @default("saei")
  action    AuditAction
  actorId   String      // مَن نفّذ الإجراء (الأدمن في الانتحال)
  targetId  String?     // المستخدم المستهدف (المنتحل)
  ip        String?
  userAgent String?
  metadata  Json?
  createdAt DateTime    @default(now())
  endedAt   DateTime?   // وقت الإنهاء (للجلسات المؤقتة كالانتحال)

  @@index([tenantId])
  @@index([actorId])
  @@index([targetId])
  @@index([action])
  @@index([createdAt])
}

enum AuditAction {
  IMPERSONATE_START
  IMPERSONATE_END
  // Phase C — تتبع نشاط أوسع
  ANNOUNCEMENT_CREATE
  ANNOUNCEMENT_UPDATE
  ANNOUNCEMENT_ARCHIVE
  APPLICANT_CLASSIFY
  PUBLISHER_CREATE
  PUBLISHER_UPDATE
  PRINTING_STAGE_ADVANCE
  SETTINGS_UPDATE
  REPORT_EXPORT
  // Phase D
  ESCALATION_TRIGGERED
  BRAND_UPDATE
  SMS_SENT
  CUSTOM_REPORT_CREATE
  CUSTOM_REPORT_UPDATE
  CUSTOM_REPORT_DELETE
}

// ============================================================
// تسليمات العمل العلمي — إصدارات الملفات (DRAFT أوّلي / منقّح)
// — حقل storagePath فارغ مبدئياً؛ يُملأ عندما يُضاف Supabase Storage
// ============================================================

model WorkSubmission {
  id         String              @id @default(cuid())
  tenantId   String              @default("saei")
  workId     String
  version    Int                 // 1, 2, 3, … تلقائي
  kind       SubmissionKind      @default(FIRST_DRAFT)
  fileName   String              // الاسم الأصلي
  mimeType   String              // application/pdf, application/msword, etc.
  size       Int                 // بايت
  storagePath String?            // مسار Supabase Storage (يُملأ لاحقاً)
  uploadedBy String               // userId
  uploadedAt DateTime            @default(now())
  notes      String?             @db.Text

  work ScientificWork @relation(fields: [workId], references: [id], onDelete: Cascade)

  @@unique([workId, version])
  @@index([tenantId])
  @@index([workId])
  @@index([uploadedBy])
  @@index([uploadedAt])
}

enum SubmissionKind {
  FIRST_DRAFT
  REVISION
  FINAL
}

// ============================================================
// الإشعارات — داخل التطبيق (DB-backed)
// ============================================================

model Notification {
  id        String           @id @default(cuid())
  tenantId  String           @default("saei")
  userId    String           // المستلم
  kind      NotificationKind
  title     String
  body      String?          @db.Text
  link      String?          // مسار للنقر داخل التطبيق
  metadata  Json?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([tenantId])
  @@index([userId, readAt])
  @@index([userId, createdAt])
  @@index([kind])
}

enum NotificationKind {
  STAGE_CHANGED
  REVIEW_ASSIGNED
  REVIEW_SUBMITTED
  SUBMISSION_RECEIVED
  DEADLINE_APPROACHING
  DEADLINE_OVERDUE
  CONTRACT_SIGNED
  CONTRACT_SENT
  // Phase C — أنواع جديدة
  ANNOUNCEMENT_PUBLISHED
  APPLICANT_ACCEPTED
  APPLICANT_REJECTED
  PRINTING_STAGE_CHANGED
  REPORT_READY
  GENERIC
}

// ============================================================
// العقود — أبحاث/نشر/تحرير مع علامات صلاحيات ودفعات
// ============================================================

model Contract {
  id        String         @id @default(cuid())
  tenantId  String         @default("saei")
  workId    String
  kind      ContractKind   @default(RESEARCH)
  status    ContractStatus @default(DRAFT)
  title     String
  body      String         @db.Text   // قالب نصّي قابل للطباعة
  startsAt  DateTime?
  endsAt    DateTime?
  value     Decimal?       @db.Decimal(12, 2)
  currency  String         @default("SAR")
  partyName String                                      // اسم الطرف الآخر (الباحث/الناشر)
  partyEmail String?                                    // اختياري
  signedById String?                                    // userId — مَن وقَّع
  signedAt   DateTime?
  signatureNote String?
  milestones Json?         // [{label, dueDate, amount, paidAt?}]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  work ScientificWork @relation(fields: [workId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([workId])
  @@index([status])
  @@index([endsAt])
}

enum ContractKind {
  RESEARCH
  PUBLISHING
  EDITING
}

enum ContractStatus {
  DRAFT
  SENT
  SIGNED
  EXPIRED
  CANCELLED
}

// ============================================================
// Phase C — إعلانات الأولويات البحثية (Research Priorities)
// ============================================================

model Announcement {
  id              String             @id @default(cuid())
  tenantId        String             @default("saei")
  title           String
  body            String             @db.Text
  requirements    String?            @db.Text   // متطلبات التقديم
  specialty       String?            // التخصص المستهدف
  targetCount     Int                @default(1) // عدد الأعمال المستهدفة
  status          AnnouncementStatus @default(DRAFT)
  publishedAt     DateTime?
  applyDeadline   DateTime?
  createdById     String
  archivedAt      DateTime?
  deletedAt       DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  applicants      Applicant[]

  @@index([tenantId])
  @@index([status])
  @@index([publishedAt])
  @@index([applyDeadline])
}

enum AnnouncementStatus {
  DRAFT       // مسودّة
  PUBLISHED   // منشور
  CLOSED      // أُغلق التقديم
  ARCHIVED    // مؤرشف
}

// ============================================================
// Phase C — متقدّمون لإعلان (يحوي بيانات السيرة الذاتية ومرفقات)
// ============================================================

model Applicant {
  id              String                @id @default(cuid())
  tenantId        String                @default("saei")
  announcementId  String
  fullName        String
  email           String?
  phone           String?
  cvText          String?               @db.Text   // ملخّص السيرة (نصيّاً)
  cvStoragePath   String?               // مسار السيرة في Supabase Storage (PDF)
  qualifications  String?               @db.Text
  publicationsCount Int                 @default(0)
  yearsExperience   Int                 @default(0)
  // التقييم
  classification  ApplicantClassification @default(PENDING)
  scoreExpertise  Int?                  // 0-100
  scorePublications Int?                // 0-100
  scoreFit        Int?                  // 0-100
  scoreTotal      Int?                  // محسوب على السيرفر (مرجَّح)
  evaluatedById   String?               // userId
  evaluatedAt     DateTime?
  notes           String?               @db.Text
  // مراسلات
  notificationSentAt DateTime?
  deletedAt       DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([announcementId])
  @@index([classification])
}

enum ApplicantClassification {
  PENDING              // لم يُصنَّف بعد
  SUITABLE             // مناسب
  PARTIALLY_SUITABLE   // مناسب جزئياً
  UNSUITABLE           // غير مناسب
}

// ============================================================
// Phase C — الناشرون / مكاتب الطباعة
// ============================================================

model Publisher {
  id          String       @id @default(cuid())
  tenantId    String       @default("saei")
  name        String
  city        String?
  country     String?      @default("SA")
  contactName String?
  contactPhone String?
  contactEmail String?
  // أداء
  rating      Int?         // 1-5 (يُحدّث يدوياً)
  totalJobs   Int          @default(0)
  notes       String?      @db.Text
  active      Boolean      @default(true)
  deletedAt   DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  printingJobs PrintingJob[]

  @@index([tenantId])
  @@index([active])
}

// ============================================================
// Phase C — أوامر الطباعة (مرحلة 11-12 من سير العمل)
// — كل عمل قد يكون له PrintingJob واحد عندما يصل لمرحلة الإنتاج
// ============================================================

model PrintingJob {
  id          String              @id @default(cuid())
  tenantId    String              @default("saei")
  workId      String              @unique
  publisherId String
  stage       PrintingStage       @default(FILE_RECEIVED)
  copies      Int                 @default(0)
  cost        Decimal?            @db.Decimal(12, 2)
  currency    String              @default("SAR")
  receivedAt  DateTime?
  designReviewAt DateTime?
  printingAt  DateTime?
  deliveredAt DateTime?
  expectedDeliveryAt DateTime?
  notes       String?             @db.Text
  deletedAt   DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  publisher   Publisher           @relation(fields: [publisherId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([publisherId])
  @@index([stage])
  @@index([expectedDeliveryAt])
}

enum PrintingStage {
  FILE_RECEIVED      // استلام الملف
  DESIGN_REVIEW      // مراجعة التصميم
  PRINTING           // قيد الطباعة
  FINAL_DELIVERY     // تسليم نهائي
}

// ============================================================
// Phase C — تفضيلات إشعارات المستخدم (per-user, per-kind toggles)
// ============================================================

model NotificationPreference {
  id        String           @id @default(cuid())
  tenantId  String           @default("saei")
  userId    String
  kind      NotificationKind
  inApp     Boolean          @default(true)
  email     Boolean          @default(true)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@unique([userId, kind])
  @@index([tenantId])
  @@index([userId])
}

// ============================================================
// Phase C — إعدادات النظام العامة (key/value JSON)
// ============================================================

model SystemSetting {
  id          String   @id @default(cuid())
  tenantId    String   @default("saei")
  key         String   @unique
  value       Json     // قيمة مرنة (string/number/object)
  description String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
}

// ============================================================
// Phase D — Escalation Rules (تصاعد الإشعارات الزمني)
// ============================================================

model EscalationRule {
  id          String           @id @default(cuid())
  tenantId    String           @default("saei")
  name        String
  kind        NotificationKind // النوع المُتصاعد له
  // متى ينطلق التصاعد: بعد كم ساعة من إنشاء الإشعار غير المقروء
  triggerAfterHours Int        @default(24)
  // مستوى التصاعد (1, 2, 3) — يحدد لمن يصل
  level       Int              @default(1)
  // أدوار المستلمين الجدد عند التصاعد
  escalateToRoles String[]     @default([])
  // قنوات التصاعد
  emailEnabled  Boolean        @default(true)
  smsEnabled    Boolean        @default(false)
  active        Boolean        @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([tenantId])
  @@index([kind])
  @@index([active])
}

// ============================================================
// Phase D — سجل رسائل SMS (Twilio fallback to email)
// ============================================================

model SmsLog {
  id          String         @id @default(cuid())
  tenantId    String         @default("saei")
  toNumber    String
  body        String         @db.Text
  status      SmsStatus      @default(QUEUED)
  provider    String?        // "twilio", "fallback-email", etc.
  providerId  String?        // SID من Twilio
  errorMessage String?
  cost        Decimal?       @db.Decimal(10, 4) // بالدولار
  sentAt      DateTime?
  createdAt   DateTime       @default(now())

  @@index([tenantId])
  @@index([status])
  @@index([createdAt])
}

enum SmsStatus {
  QUEUED
  SENT
  DELIVERED
  FAILED
}

// ============================================================
// Phase D — تقارير مخصصة محفوظة (بدون drag-drop builder، فقط CRUD لقوالب)
// ============================================================

model CustomReport {
  id          String   @id @default(cuid())
  tenantId    String   @default("saei")
  name        String
  description String?
  // تعريف التقرير: { entity: "ScientificWork", filters: [...], groupBy: ..., aggregations: ... }
  definition  Json
  createdById String
  isShared    Boolean  @default(false)
  lastRunAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
  @@index([createdById])
}

// ============================================================
// Phase D — إعدادات هوية بصرية (CSS variables runtime override)
// — صف واحد فقط في النظام (singleton-via-key)
// ============================================================

model BrandSetting {
  id            String   @id @default(cuid())
  tenantId      String   @unique @default("saei")
  primaryColor  String   @default("#5E5495") // saei-purple
  secondaryColor String  @default("#00D4DD") // saei-teal
  accentColor   String   @default("#C9A84C") // saei-gold
  logoUrl       String?
  fontFamily    String   @default("Cairo")
  updatedById   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}


