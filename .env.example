# ============================================================
# نظام إدارة الأعمال العلمية — مؤسسة ساعي
# انسخ إلى .env (للتطوير) أو إلى Vercel Env Vars (للإنتاج)
# ============================================================

# ============================================================
# قاعدة البيانات (PostgreSQL، إلزامي)
# ============================================================
# Supabase patterns:
#   - تطوير محلي: Direct connection (port 5432) عبر IPv6 على معظم الأنظمة
#   - إنتاج Vercel: Transaction Pooler (port 6543) — IPv4، أسرع
#   - بدائل: Vercel Postgres / Neon / Railway
DATABASE_URL="postgresql://postgres:PASSWORD@db.PROJECT_ID.supabase.co:5432/postgres"

# للإنتاج على Vercel، استخدم Transaction Pooler بدلاً من Direct:
# DATABASE_URL="postgresql://postgres.PROJECT_ID:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# ============================================================
# NextAuth (إلزامي)
# ============================================================
# سرّ توقيع JWT — توليد قيمة عشوائية ٣٢ بايت:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# لا تستخدم نصاً قابلاً للتنبؤ في الإنتاج (تجنّب أسماء/تواريخ).
NEXTAUTH_SECRET="REPLACE_WITH_RANDOM_BASE64_32_BYTES"

# URL القاعدي للتطبيق
# تطوير: http://localhost:3000
# إنتاج: https://your-domain.vercel.app (يجب أن يطابق Vercel أو الـcustom domain)
NEXTAUTH_URL="http://localhost:3000"

# ============================================================
# اختياري — تشغيل البريد للتذكيرات (لاحقاً)
# ============================================================
# RESEND_API_KEY=""
# RESEND_FROM="نظام ساعي <noreply@example.com>"
